<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:background="?attr/colorPrimaryContainer"
    android:orientation="vertical" android:padding="24dp" android:paddingTop="40dp">
    <ImageView android:layout_width="56dp" android:layout_height="56dp"
        android:src="@mipmap/ic_launcher" android:layout_marginBottom="12dp" />
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/app_name" android:textAppearance="?attr/textAppearanceTitleLarge"
        android:textColor="?attr/colorOnPrimaryContainer" />
    <TextView android:id="@+id/tvNavVersion"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?attr/colorOnPrimaryContainer" android:alpha="0.7" />
</LinearLayout>
