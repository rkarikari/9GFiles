<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="32dp">

        <!-- ── Header ──────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Publisher Tool"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Encrypt files for a specific device using its RSA public key."
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="20dp"/>

        <!-- ── Card 1 · This Device's Public Key ───────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THIS DEVICE"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorPrimary"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_lock_silent_mode_off"
                        android:background="@drawable/bg_icon_rounded"
                        android:padding="8dp"
                        app:tint="?attr/colorPrimary"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Public Key Fingerprint"
                            android:textAppearance="?attr/textAppearanceTitleMedium"/>

                        <TextView
                            android:id="@+id/tvDeviceFingerprint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Loading…"
                            android:fontFamily="monospace"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Share this device's public key with a publisher so they can encrypt files exclusively for you."
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopyMyKey"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Copy Key"
                        android:layout_marginEnd="8dp"
                        app:icon="@drawable/ic_content_copy"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnShareMyKey"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Share Key"
                        app:icon="@drawable/ic_share"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Card 2 · Recipient Key ───────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEP 1 — RECIPIENT DEVICE KEY"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorPrimary"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Paste the RSA-2048 public key of the target device (from Settings → Share Public Key on that device)."
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="-----BEGIN PUBLIC KEY-----"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRecipientKey"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine|textNoSuggestions"
                        android:minLines="4"
                        android:maxLines="8"
                        android:fontFamily="monospace"
                        android:textSize="11sp"
                        android:gravity="top"
                        android:scrollbars="vertical"
                        android:overScrollMode="always"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Key status row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/ivKeyStatusIcon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_lock_silent_mode_off"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tvKeyStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="No key entered"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Card 3 · Files ──────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEP 2 — ADD FILES"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorPrimary"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Any file type. Output saves to Downloads as &lt;filename&gt;.9genc — transfer to the recipient device."
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="14dp"/>

                <!-- File queue -->
                <TextView
                    android:id="@+id/tvEmptyQueue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No files added yet"
                    android:gravity="center"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:visibility="visible"/>

                <LinearLayout
                    android:id="@+id/llFileQueue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp"/>

                <!-- Add files button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddFiles"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Add Files…"
                    app:icon="@drawable/ic_add"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Card 4 · Encrypt ────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEP 3 — ENCRYPT &amp; EXPORT"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorPrimary"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Progress bar (hidden by default) -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    app:trackCornerRadius="4dp"/>

                <TextView
                    android:id="@+id/tvStatusHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Paste the recipient device's public key, then add files"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="16dp"/>

                <!-- Format reference chip -->
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Format: 9GEK  ·  RSA-OAEP/SHA-256 + AES-256-GCM"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:clickable="false"
                    android:focusable="false"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.Material3.Chip.Assist"/>

                <!-- Row 1: Clear + Encrypt & Save to Downloads -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end"
                    android:layout_marginBottom="10dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearAll"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clear"
                        android:enabled="false"
                        android:layout_marginEnd="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEncryptAll"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Encrypt &amp; Save"
                        android:enabled="false"
                        app:icon="@drawable/ic_save"/>
                </LinearLayout>

                <!-- Row 2: Encrypt & Send via Wi-Fi Direct -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEncryptAndSend"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Encrypt &amp; Send via Wi-Fi Direct"
                    android:enabled="false"
                    app:icon="@drawable/ic_wifi_direct"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
