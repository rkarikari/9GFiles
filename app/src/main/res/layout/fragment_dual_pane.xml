<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!--
        Dual-pane control strip.
        On phones (portrait): acts as a tab switcher — tap a button to show that pane.
        On tablets: both panes are always visible; strip just labels them.
    -->
    <LinearLayout
        android:id="@+id/layoutPaneControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/colorSurfaceVariant"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:elevation="2dp">

        <!-- Segmented toggle: Left Pane / Right Pane -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/togglePaneGroup"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPaneLeft"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="◀  Left Pane"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPaneRight"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Right Pane  ▶"
                android:textSize="13sp"
                android:textStyle="bold" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Swap button row — below the toggle, full-width label -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSwapPanes"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="6dp"
            android:text="⇄  Swap Pane Paths"
            android:textSize="12sp"
            app:icon="@drawable/ic_content_paste"
            app:iconSize="16dp"
            app:iconGravity="textStart" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutlineVariant" />

    <androidx.slidingpanelayout.widget.SlidingPaneLayout
        android:id="@+id/slidingPane"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:id="@+id/paneLeft"
            android:layout_width="320dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <FrameLayout
            android:id="@+id/paneRight"
            android:layout_width="320dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

    </androidx.slidingpanelayout.widget.SlidingPaneLayout>

</LinearLayout>
