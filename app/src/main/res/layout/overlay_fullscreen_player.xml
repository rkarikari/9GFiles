<?xml version="1.0" encoding="utf-8"?>
<!--
    overlay_fullscreen_player.xml
    Full-screen video playback overlay.
    Hosted in a Dialog that covers status bar + navigation bar.
    Controls auto-hide; tap anywhere on the video surface to reveal them.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Video surface (full screen) -->
    <SurfaceView
        android:id="@+id/fsSurfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <!-- Controls overlay (auto-hides) -->
    <FrameLayout
        android:id="@+id/fsControlsOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Top gradient bar: title + exit button -->
        <LinearLayout
            android:id="@+id/fsTopBar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_gravity="top"
            android:background="@drawable/bg_fs_controls_top"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="4dp">

            <ImageButton
                android:id="@+id/fsBtnExitFullscreen"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_fullscreen_exit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Exit full screen" />

            <TextView
                android:id="@+id/fsTvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:singleLine="true"
                android:ellipsize="marquee"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Bottom gradient bar: seek + transport controls -->
        <LinearLayout
            android:id="@+id/fsBottomBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_fs_controls_bottom"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="16dp"
            android:paddingBottom="12dp">

            <!-- Time + seek row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/fsTvCurrentTime"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:gravity="end" />

                <SeekBar
                    android:id="@+id/fsSeekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/fsTvTotalTime"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Transport controls row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="4dp">

                <ImageButton
                    android:id="@+id/fsBtnPrevious"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_media_previous"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Previous track" />

                <ImageButton
                    android:id="@+id/fsBtnRewind"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_media_rew"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Rewind 10s" />

                <ImageButton
                    android:id="@+id/fsBtnPlay"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@android:drawable/ic_media_play"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Play / Pause" />

                <ImageButton
                    android:id="@+id/fsBtnFastForward"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_media_ff"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Fast-forward 10s" />

                <ImageButton
                    android:id="@+id/fsBtnNext"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_media_next"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Next track" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
