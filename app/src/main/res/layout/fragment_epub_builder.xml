<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="32dp">

        <!-- ── Header ──────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ePub eBook Builder"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Convert PDF, DOCX, TXT, Markdown and HTML files into a standard .epub eBook."
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="20dp"/>

        <!-- ══ STEP 1 — BOOK METADATA ══════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEP 1 — BOOK METADATA"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorPrimary"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Title -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Book Title *"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEbookTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords"
                        android:imeOptions="actionNext"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Author -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Author"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEbookAuthor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:imeOptions="actionNext"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Language -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Language"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_marginBottom="12dp">
                    <AutoCompleteTextView
                        android:id="@+id/actvLanguage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Publisher -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Publisher (optional)"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEbookPublisher"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords"
                        android:imeOptions="actionNext"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Description -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Description / Synopsis (optional)"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="16dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEbookDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine|textCapSentences"
                        android:minLines="2"
                        android:maxLines="5"
                        android:gravity="top"
                        android:scrollbars="vertical"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Cover image row -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cover Image"
                    android:textAppearance="?attr/textAppearanceTitleSmall"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/ivCoverThumb"
                        android:layout_width="64dp"
                        android:layout_height="80dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_file_image"
                        android:background="@drawable/bg_icon_rounded"
                        android:padding="12dp"
                        app:tint="@color/category_document"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:id="@+id/tvCoverHint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No cover image selected"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginBottom="8dp"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnPickCover"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pick Image"
                                android:layout_marginEnd="8dp"
                                app:icon="@drawable/ic_file_image"/>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnRemoveCover"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Remove"
                                android:visibility="gone"
                                app:icon="@drawable/ic_close"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ STEP 2 — CHAPTERS ════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEP 2 — CHAPTERS"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorPrimary"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Add PDF, DOCX, TXT, Markdown or HTML files. Each file becomes a chapter. Tap a chapter title to rename it; use ↑ ↓ to reorder."
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="14dp"/>

                <TextView
                    android:id="@+id/tvEmptyChapters"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No chapters added yet — tap Add Files below"
                    android:gravity="center"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:paddingTop="8dp"
                    android:paddingBottom="12dp"
                    android:visibility="visible"/>

                <LinearLayout
                    android:id="@+id/llChapterList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddChapterFiles"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Add Source Files…"
                    app:icon="@drawable/ic_add"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ STEP 3 — STYLE ═══════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEP 3 — STYLE"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorPrimary"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Theme -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reading Theme"
                    android:textAppearance="?attr/textAppearanceTitleSmall"
                    android:layout_marginBottom="10dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupTheme"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    android:layout_marginBottom="18dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipLight"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="☀ Light"
                        android:checked="true"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSepia"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📜 Sepia"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDark"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌙 Dark"/>

                </com.google.android.material.chip.ChipGroup>

                <!-- Font size -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Font Size"
                        android:textAppearance="?attr/textAppearanceTitleSmall"/>

                    <TextView
                        android:id="@+id/tvFontSizeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="16pt"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorPrimary"
                        android:minWidth="36dp"
                        android:gravity="end"/>
                </LinearLayout>

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderFontSize"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="10"
                    android:valueTo="24"
                    android:stepSize="1"
                    android:value="16"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ STEP 4 — BUILD ═══════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEP 4 — BUILD"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorPrimary"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    app:trackCornerRadius="4dp"/>

                <TextView
                    android:id="@+id/tvBuildStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enter a book title and add chapter files to begin"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="16dp"/>

                <!-- Format info chip -->
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Output: EPUB 3.0  ·  Saved to Downloads"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:clickable="false"
                    android:focusable="false"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.Material3.Chip.Assist"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBuildEpub"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Build ePub"
                    android:enabled="false"
                    android:layout_marginBottom="8dp"
                    app:icon="@drawable/ic_save"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnShareEpub"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Share"
                        android:visibility="gone"
                        android:layout_marginEnd="8dp"
                        app:icon="@drawable/ic_share"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOpenEpub"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Open"
                        android:visibility="gone"
                        app:icon="@drawable/ic_file_document"/>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
