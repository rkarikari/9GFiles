<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Status bar: line count / char count -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:background="?attr/colorSurfaceVariant"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvFileInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:text="Loading…" />

        <TextView
            android:id="@+id/tvEditingBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EDITING"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorPrimary"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Loading indicator -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/loadingIndicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone" />

    <!-- Error view -->
    <TextView
        android:id="@+id/tvError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:textColor="?attr/colorError"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:visibility="gone" />


    <!-- Markdown preview WebView (hidden by default) -->
    <WebView
        android:id="@+id/webviewPreview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <!-- Text content / editor -->
    <ScrollView
        android:id="@+id/scrollEditor"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <EditText
            android:id="@+id/editorContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurface"
            android:enabled="false"
            android:fontFamily="monospace"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:padding="16dp"
            android:scrollbars="vertical"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurfaceVariant"
            android:textIsSelectable="true"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.5"
            android:letterSpacing="0.01" />

    </ScrollView>

</LinearLayout>
